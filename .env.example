# PostgreSQL
DATABASE_URL=postgresql://kontia_app:password@localhost:5432/kontia

# n8n Webhooks
WEBHOOK_URL=https://tu-n8n.example.com/webhook
# Secreto compartido Express->n8n (los workflows lo verifican en x-kontia-secret).
# Genera uno: openssl rand -hex 24. Configura el MISMO valor en los workflows n8n.
WEBHOOK_SECRET=

# MinIO
MINIO_URL=https://tu-minio.example.com/facturas

# JWT Secret (genera uno seguro: openssl rand -hex 32)
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_64_chars

# Server
PORT=3001
NODE_ENV=production
